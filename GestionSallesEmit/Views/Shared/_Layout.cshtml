<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GestionSallesEmit</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestionSallesEmit.styles.css" asp-append-version="true" />
</head>
<body class="app-body @(ViewData["BodyClass"] ?? "")">
    <header class="app-header shadow-sm position-sticky top-0 zindex-fixed">
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">GSE</span>
                    <span class="ms-2">GestionSallesEmit</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Tableau de bord</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Salles" asp-action="Index">🏫 Salles</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Enseignants" asp-action="Index">👨‍🏫 Enseignants</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cours" asp-action="Index">📚 Cours</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Seances" asp-action="Index">📆 Emploi du Temps</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="app-alert-container px-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-banner" role="alert">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-banner" role="alert">
                @TempData["ErrorMessage"]
            </div>
        }
    </div>
    <div class="main-wrapper">
        <div class="container">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GestionSallesEmit - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
   <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <!-- Toast container for notifications -->
    <div id="toastContainer" class="position-fixed top-0 end-0 p-3" style="z-index:1080"></div>
    <script>
        (function(){
            if (!window.signalR) return;
            const connection = new signalR.HubConnectionBuilder().withUrl('/hubs/notifications').withAutomaticReconnect().build();
            function showToast(title, body) {
                const id = 't'+Date.now();
                const wrapper = document.createElement('div');
                wrapper.innerHTML = `
                    <div id="${id}" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                      <div class="toast-header">
                        <strong class="me-auto">${title}</strong>
                        <small class="text-muted">maintenant</small>
                        <button type="button" class="btn-close ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
                      </div>
                      <div class="toast-body">${body}</div>
                    </div>`;
                const container = document.getElementById('toastContainer');
                container.appendChild(wrapper);
                const toastEl = wrapper.querySelector('.toast');
                const bsToast = new bootstrap.Toast(toastEl, { delay: 8000 });
                bsToast.show();
                toastEl.addEventListener('hidden.bs.toast', ()=> wrapper.remove());
            }

            connection.on('SeanceCreated', (payload) => {
                try {
                    const title = 'Nouvelle séance';
                    const body = `${payload.jour} ${payload.heureDebut} - ${payload.heureFin} (salle ${payload.salleId})`;
                    showToast(title, body);
                    if (location.pathname.startsWith('/Seances')) {
                        if (typeof refreshCalendar === 'function') refreshCalendar();
                    }
                    if (location.pathname.startsWith('/Salles')) {
                        if (typeof loadSummary === 'function') loadSummary();
                        if (typeof load === 'function') load();
                    }
                } catch (e) { console.error(e); }
            });

            window.showFloatingMessage = function(type, title, message) {
                const icon = type === 'success' ? '✅' : type === 'error' ? '⚠️' : 'ℹ️';
                showToast(`${icon} ${title}`, message);
            };

            connection.start().catch(err => console.error('SignalR error', err));
        })();
    </script>
</body>
</html>
