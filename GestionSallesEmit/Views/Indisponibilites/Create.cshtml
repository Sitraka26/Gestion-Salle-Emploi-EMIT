@model GestionSallesEmit.Models.Indisponibilite
<div class="container mt-4"><div class="row justify-content-center"><div class="col-md-6"><div class="card shadow">
    <div class="card-header bg-primary text-white"><h3 class="mb-0">Déclarer une Indisponibilité</h3></div>
    <div class="card-body">
        <form asp-action="Create">
            <input type="hidden" asp-for="EnseignantId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label class="form-label">Jour</label>
                <select asp-for="Jour" class="form-select">
                    <option value="">-- Choisir --</option>
                    <option>Lundi</option><option>Mardi</option><option>Mercredi</option>
                    <option>Jeudi</option><option>Vendredi</option><option>Samedi</option>
                </select>
                <span asp-validation-for="Jour" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Heure Début</label>
                <input asp-for="HeureDebut" type="time" class="form-control" />
                <span asp-validation-for="HeureDebut" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Heure Fin</label>
                <input asp-for="HeureFin" type="time" class="form-control" />
                <span asp-validation-for="HeureFin" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Raison (optionnel)</label>
                <input asp-for="Raison" class="form-control" placeholder="ex: Cours à l'Université d'Antananarivo" />
            </div>
            <div class="d-flex justify-content-between"><a asp-action="Index" asp-route-enseignantId="@Model.EnseignantId" class="btn btn-secondary">Retour</a><button type="submit" class="btn btn-primary">Enregistrer</button></div>
        </form>
    </div>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }s