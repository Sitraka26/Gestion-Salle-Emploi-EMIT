@model IEnumerable<GestionSallesEmit.Models.Seance>

<div class="container-fluid mt-5 px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient text-white py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="mb-0" style="font-weight: 700;">📆 Emploi du Temps - EMIT</h2>
                            <small class="text-white-50">Vue des sessions de cours planifiées</small>
                        </div>
                        <a asp-action="Create" class="btn btn-light fw-bold" style="font-size: 1.1rem; padding: 10px 20px;">
                            <i class="fas fa-plus"></i> Planifier un Cours
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    <!-- Tableau des séances -->
                    <div class="table-responsive">
                        @if (Model.Any())
                        {
                            <table class="table table-hover table-striped table-bordered">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th class="text-center" width="12%">📅 Jour</th>
                                        <th class="text-center" width="15%">🕒 Horaire</th>
                                        <th width="25%">📚 Cours</th>
                                        <th width="20%">👨‍🏫 Enseignant</th>
                                        <th class="text-center" width="15%">🏫 Salle</th>
                                        <th class="text-center" width="13%">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var seance in Model.OrderBy(s => Array.IndexOf(new[] { "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi" }, s.Jour)).ThenBy(s => s.HeureDebut))
                                    {
                                        <tr class="align-middle">
                                            <td class="text-center">
                                                <span class="badge bg-primary fs-6">@seance.Jour</span>
                                            </td>
                                            <td class="text-center">
                                                <strong>@seance.HeureDebut</strong> - @seance.HeureFin
                                            </td>
                                            <td>
                                                <strong>@seance.Cours?.NomCours</strong>
                                            </td>
                                            <td>
                                                @seance.Enseignant?.Nom @seance.Enseignant?.Prenom
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info fs-6">@seance.Salle?.NomSalle</span>
                                            </td>
                                            <td class="text-center">
                                                <a href="#" class="btn btn-sm btn-outline-warning" title="Modifier">✏️</a>
                                                <a href="#" class="btn btn-sm btn-outline-danger" title="Supprimer">🗑️</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="alert alert-info text-center py-5" role="alert">
                                <h4 class="mb-2">📌 Aucune séance planifiée</h4>
                                <p class="mb-3">Commencez par planifier votre première session de cours.</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Créer une Séance
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FullCalendar (optionnel pour vue calendrier) -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Vérifier que FullCalendar est disponible
        if (typeof FullCalendar === 'undefined') {
            console.warn('FullCalendar pas disponible. Utilisation du mode tableau.');
            return;
        }

        // Mode calendrier optionnel (tu peux ajouter un bouton pour basculer)
        console.log('FullCalendar est chargé et prêt.');
    });
</script>