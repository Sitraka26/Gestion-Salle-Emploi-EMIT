@{
    ViewData["Title"] = "Tableau de Bord - EMIT";
}

<div class="container mt-4">
    <!-- Section principale Bienvenue (Moderne et Pro) -->
    <div class="p-5 mb-4 bg-light rounded-3 border shadow-sm">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold text-dark">🏫 Système de Gestion EMIT</h1>
            <p class="col-md-8 fs-4 text-muted">Bienvenue sur votre application de gestion des salles et de planification des emplois du temps.</p>
        </div>
    </div>

    <!-- Grille des raccourcis vers tes modules fonctionnels -->
    <div class="row g-4 text-center">
        <!-- Module Salles -->
        <div class="col-md-4">
            <div class="card h-100 border-start border-primary border-4 shadow-sm">
                <div class="card-body py-4">
                    <h5 class="card-title text-primary fw-bold fs-4">Salles</h5>
                    <p class="card-text text-muted">Consulter et gérer les capacités des salles.</p>
                    <a asp-controller="Salles" asp-action="Index" class="btn btn-outline-primary fw-bold">Ouvrir le module</a>
                </div>
            </div>
        </div>

        <!-- Module Enseignants -->
        <div class="col-md-4">
            <div class="card h-100 border-start border-success border-4 shadow-sm">
                <div class="card-body py-4">
                    <h5 class="card-title text-success fw-bold fs-4">Enseignants</h5>
                    <p class="card-text text-muted">Gérer la liste du corps enseignant.</p>
                    <a asp-controller="Enseignants" asp-action="Index" class="btn btn-outline-success fw-bold">Ouvrir le module</a>
                </div>
            </div>
        </div>

        <!-- Module Cours -->
        <div class="col-md-4">
            <div class="card h-100 border-start border-warning border-4 shadow-sm">
                <div class="card-body py-4">
                    <h5 class="card-title text-warning fw-bold fs-4">Cours</h5>
                    <p class="card-text text-muted">Suivre les matières et les crédits associés.</p>
                    <a asp-controller="Cours" asp-action="Index" class="btn btn-outline-warning fw-bold">Ouvrir le module</a>
                </div>
            </div>
        </div>
    </div>
</div>