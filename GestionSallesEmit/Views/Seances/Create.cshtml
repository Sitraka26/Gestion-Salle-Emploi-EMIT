@model GestionSallesEmit.Models.Seance

<div class="container mt-4"><div class="row justify-content-center"><div class="col-md-6"><div class="card shadow">
    <div class="card-header bg-primary text-white"><h3 class="mb-0">Planifier une Séance</h3></div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>
            <div class="mb-3">
                <label class="form-label">Jour</label>
                <select asp-for="Jour" class="form-select">
                    <option>Lundi</option><option>Mardi</option><option>Mercredi</option>
                    <option>Jeudi</option><option>Vendredi</option><option>Samedi</option>
                </select>
            </div>
            <div class="mb-3"><label class="form-label">Heure Début</label><input asp-for="HeureDebut" type="time" class="form-control" required /></div>
            <div class="mb-3"><label class="form-label">Heure Fin</label><input asp-for="HeureFin" type="time" class="form-control" required /></div>
            <div class="mb-3"><label class="form-label">Cours</label><select asp-for="CoursId" class="form-select" asp-items="ViewBag.Cours"></select></div>
            <div class="mb-3"><label class="form-label">Enseignant</label><select asp-for="EnseignantId" class="form-select" asp-items="ViewBag.Enseignants"></select></div>
            <div class="mb-3"><label class="form-label">Salle</label><select asp-for="SalleId" class="form-select" asp-items="ViewBag.Salles"></select></div>
            <div class="d-flex justify-content-between"><a asp-action="Index" class="btn btn-secondary">Retour</a><button type="submit" class="btn btn-primary">Enregistrer</button></div>
        </form>
    </div>
</div></div></div></div>