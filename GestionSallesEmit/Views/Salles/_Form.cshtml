@model GestionSallesEmit.Models.Salle

<form method="post" asp-action="@(Model.Id == 0 ? "Create" : "Edit")" asp-route-id="@(Model.Id)">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="NomSalle" class="form-label">Nom de la salle</label>
        <input asp-for="NomSalle" class="form-control form-control-lg" placeholder="Ex: Salle A101" />
        <span asp-validation-for="NomSalle" class="invalid-feedback d-block"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Capacite" class="form-label">Capacité</label>
        <input asp-for="Capacite" type="number" min="1" class="form-control form-control-lg" placeholder="Ex: 50" />
        <span asp-validation-for="Capacite" class="invalid-feedback d-block"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
    </div>

    <partial name="_ValidationScriptsPartial" />
</form>