@model GestionSallesEmit.Models.Salle

@{
    ViewData["Title"] = "Ajouter une Salle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">Ajouter une Nouvelle Salle</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="form-group mb-3">
                            <label asp-for="NomSalle" class="form-label">Nom de la Salle</label>
                            <input asp-for="NomSalle" class="form-control" placeholder="Ex: Salle 101, Labo Info..." required />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Capacite" class="form-label">Capacité d'accueil</label>
                            <input asp-for="Capacite" type="number" class="form-control" placeholder="Ex: 50" required />
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Retour</a>
                            <button type="submit" class="btn btn-primary">Enregistrer la Salle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>