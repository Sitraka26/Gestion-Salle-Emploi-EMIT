@model GestionSallesEmit.Models.Enseignant
@{
    ViewData["Title"] = "Supprimer Enseignant";
}

<div class="container mt-4">
    <h2>Supprimer l'enseignant</h2>
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@Model.Nom @Model.Prenom</h5>
            <p class="card-text">Email : @Model.Email</p>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
        <a asp-action="Index" class="btn btn-secondary">Annuler</a>
    </form>
</div>
