@model IEnumerable<GestionSallesEmit.Models.Enseignant>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="text-primary">Gestion des Enseignants</h1>
        <a asp-action="Create" class="btn btn-success">➕ Ajouter un Enseignant</a>
    </div>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr><th>Nom</th><th>Prénom</th><th>Email</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr><td>@item.Nom</td><td>@item.Prenom</td><td>@item.Email</td></tr>
            }
        </tbody>
    </table>
</div>