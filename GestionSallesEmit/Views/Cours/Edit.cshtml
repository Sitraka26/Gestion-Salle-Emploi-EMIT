@model GestionSallesEmit.Models.Cours
@{
    ViewData["Title"] = "Modifier Cours";
}

<div class="container mt-4">
    <h2>Modifier le cours</h2>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label">Nom du Cours</label>
            <input asp-for="NomCours" class="form-control" />
            <span asp-validation-for="NomCours" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Crédits</label>
            <input asp-for="Credit" type="number" class="form-control" />
            <span asp-validation-for="Credit" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-secondary">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
