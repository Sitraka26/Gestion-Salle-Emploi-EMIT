@{
    ViewData["Title"] = "Cours";
}

<div class="container mt-4">
    <section class="page-header">
        <div>
            <p class="text-uppercase text-primary small mb-2">Cours</p>
            <h1 class="page-title">Managez vos matières avec clarté</h1>
            <p class="page-description">Recherchez et triez rapidement les cours, puis ouvrez le formulaire d’ajout depuis une interface élégante et fluide.</p>
        </div>
        <div class="page-actions">
            <button id="addCourseBtn" class="btn btn-primary btn-lg">➕ Ajouter un cours</button>
            <button id="refreshBtn" class="btn btn-soft-secondary btn-lg">🔄 Rafraîchir</button>
        </div>
    </section>

    <section class="section-panel">
        <div class="row gy-3 mb-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stat-label">Total de cours</div>
                    <div class="stat-value" id="coursesTotal">0</div>
                    <small class="text-muted">Cours actifs et visibles.</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stat-label">Crédit moyen</div>
                    <div class="stat-value" id="coursesAvgCredit">0</div>
                    <small class="text-muted">Notez les cours les plus intensifs.</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stat-label">Cours le plus exigeant</div>
                    <div class="stat-value" id="coursesTopCourse">Aucun</div>
                    <small class="text-muted">Le cours avec le plus de crédits.</small>
                </div>
            </div>
        </div>

        <div class="control-toolbar">
            <div>
                <h2 class="panel-title">Liste des cours</h2>
                <p class="text-muted mb-0">Tri et recherche en temps réel sur l’ensemble des cours.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <label class="mb-0">Filtrer Crédit</label>
                <select id="creditFilter" class="form-select d-inline-block w-auto ms-2">
                    <option value="0">Tous</option>
                    <option value="3">≥ 3 crédits</option>
                    <option value="5">≥ 5 crédits</option>
                </select>
                <button id="focusHighCredit" class="btn btn-soft-primary btn-sm">Voir cours intensifs</button>
                <label class="mb-0">Trier par</label>
                <select id="sortSelect" class="form-select d-inline-block w-auto ms-2">
                    <option value="name">Nom</option>
                    <option value="credit">Crédit (desc)</option>
                </select>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-lg-6">
                <input id="searchInput" class="form-control" placeholder="Rechercher un cours..." />
            </div>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="coursesTable">
                    <thead>
                        <tr>
                            <th>Nom du Cours</th>
                            <th style="width:140px">Crédits</th>
                            <th style="width:140px">Tag</th>
                            <th style="width:200px">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="coursesBody"></tbody>
                </table>
            </div>
        </div>

        <nav class="mt-3">
            <ul class="pagination" id="pagination"></ul>
        </nav>
    </section>

    <!-- Modal for create/edit -->
    <div class="modal fade" id="entityModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="entityModalLabel">Cours</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="entityModalBody">Chargement…</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            const pageSize = 8;
            let page = 1;
            const searchInput = document.getElementById('searchInput');
            const sortSelect = document.getElementById('sortSelect');
            const coursesBody = document.getElementById('coursesBody');
            const pagination = document.getElementById('pagination');

            function renderRow(c) {
                const badge = c.credit >= 5 ? '<span class="status-badge status-badge-primary">Très demandé</span>' : '<span class="status-badge status-badge-secondary">Standard</span>';
                return `
                    <tr>
                        <td>${c.nomCours}</td>
                        <td>${c.credit}</td>
                        <td>${badge}</td>
                        <td>
                            <a class="btn btn-sm btn-primary me-1" href="/Cours/Edit/${c.id}">Modifier</a>
                            <a class="btn btn-sm btn-danger" href="/Cours/Delete/${c.id}">Supprimer</a>
                        </td>
                    </tr>`;
            }

            const creditFilter = document.getElementById('creditFilter');
            const focusHighCredit = document.getElementById('focusHighCredit');
            const coursesTotal = document.getElementById('coursesTotal');
            const coursesAvgCredit = document.getElementById('coursesAvgCredit');
            const coursesTopCourse = document.getElementById('coursesTopCourse');

            async function loadSummary() {
                const minCredit = parseInt(creditFilter.value, 10) || 0;
                const res = await fetch(`/Cours/SummaryJson?minCredit=${minCredit}`);
                const summary = await res.json();
                coursesTotal.textContent = summary.total;
                coursesAvgCredit.textContent = summary.avgCredit;
                coursesTopCourse.textContent = summary.topCourse ? `${summary.topCourse.nomCours} (${summary.topCourse.credit})` : 'Aucun';
            }

            async function load() {
                const q = encodeURIComponent(searchInput.value || '');
                const sort = sortSelect.value;
                const minCredit = parseInt(creditFilter.value, 10) || 0;
                const res = await fetch(`/Cours/ListJson?q=${q}&sort=${sort}&page=${page}&pageSize=${pageSize}&minCredit=${minCredit}`);
                const data = await res.json();
                coursesBody.innerHTML = data.items.map(renderRow).join('');

                // pagination
                const total = data.total;
                const pages = Math.ceil(total / pageSize) || 1;
                pagination.innerHTML = '';
                for (let i = 1; i <= pages; i++) {
                    const li = document.createElement('li');
                    li.className = 'page-item' + (i === page ? ' active' : '');
                    li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                    li.addEventListener('click', (e) => { e.preventDefault(); page = i; load(); });
                    pagination.appendChild(li);
                }
            }

            document.getElementById('refreshBtn').addEventListener('click', () => { loadSummary(); load(); });
            focusHighCredit.addEventListener('click', () => {
                creditFilter.value = '5';
                loadSummary();
                page = 1;
                load();
            });
            document.getElementById('addCourseBtn').addEventListener('click', async ()=>{
                const modalEl = document.getElementById('entityModal');
                const modalBody = document.getElementById('entityModalBody');
                modalBody.innerHTML = 'Chargement…';
                const res = await fetch('/Cours/CreatePartial');
                const html = await res.text();
                modalBody.innerHTML = html;
                const modal = new bootstrap.Modal(modalEl);
                modal.show();

                // handle AJAX submit
                const form = modalBody.querySelector('form');
                form.addEventListener('submit', async (e)=>{
                    e.preventDefault();
                    const formData = new FormData(form);
                    const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
                    const post = await fetch(form.action, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData
                    });
                    if (post.headers.get('Content-Type')?.includes('application/json')) {
                        const j = await post.json();
                        if (j.success) { modal.hide(); load(); }
                    } else {
                        // assume partial html with validation
                        const txt = await post.text();
                        modalBody.innerHTML = txt;
                    }
                });
            });
            sortSelect.addEventListener('change', () => { page = 1; load(); loadSummary(); });
            creditFilter.addEventListener('change', () => { page = 1; load(); loadSummary(); });
            let debounce;
            searchInput.addEventListener('input', () => { clearTimeout(debounce); debounce = setTimeout(() => { page = 1; load(); }, 300); });

            document.addEventListener('DOMContentLoaded', () => { loadSummary(); load(); });
        })();
    </script>
}